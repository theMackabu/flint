println(trim('  hello  '));
println(trim('\n\ttabs and newlines\n'));

const s = 'hello world';
println(substr(s, 6));
println(substr(s, 0, 5));
println(substr(s, 3, 2));

println(`"world" at index: ${index_of(s, 'world')}`);
println(`"xyz" at index: ${index_of(s, 'xyz')}`);

println(replace('foo bar foo baz foo', 'foo', 'qux'));
println(replace('aaa', 'a', 'bb'));

println(upper('hello world'));
println(lower('HELLO WORLD'));

const csv = '  Alice, Bob, Charlie  ';
const clean = trim(csv);
println(`cleaned: "${clean}"`);
println(`upper: ${upper(clean)}`);
println(`first name ends at: ${index_of(clean, ',')}`);
println(`first name: ${substr(clean, 0, index_of(clean, ','))}`);

const line = 'name=flint';
const eq = index_of(line, '=');
const key = substr(line, 0, eq);
const val = substr(line, eq + 1);
println(`key="${key}" val="${val}"`);

const messy = '  HELLO, World!  ';
println(replace(trim(lower(messy)), 'hello', 'hi'));
