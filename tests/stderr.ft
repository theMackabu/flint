// logging to stderr so stdout stays clean
function log(level, msg) {
  eprintln(`[${level}] ${msg}`);
}

log('INFO', 'starting up');
log('DEBUG', 'processing data');

// stdout is for actual output
println('result: 42');

log('WARN', 'something took too long');
log('INFO', 'done');

// redirect: ./flint tests/stderr.ft 2>/dev/null  (only see stdout)
// redirect: ./flint tests/stderr.ft 2>&1          (see both)
