const pid = fork();

if (pid == 0) {
  println(`child: pid ${$`echo $$`}`);
  println('child: doing work...');
  exit(42);
} else {
  println(`parent: forked child ${pid}`);
  const status = wait();
  println(`parent: child exited with ${status}`);
}

let i = 0;
while (i < 3) {
  let p = fork();
  if (p == 0) {
    println(`worker ${i} started`);
    exit(0);
  }
  i = i + 1;
}

let w = 0;
while (w < 3) {
  wait();
  w = w + 1;
}
println('all workers done');
