const csv = 'name,age,city\nalice,30,nyc\nbob,25,sf\ncharlie,35,la';

const lines = pipe(csv, 'wc -l');
println(`rows: ${lines}`);

const found = pipe(csv, 'grep bob');
println(`found: ${found}`);

const names = pipe(csv, "awk -F, 'NR>1 {print $1}'");
println('names:');
println(names);

const sorted = pipe(csv, "tail -n+2 | sort -t, -k2 -n | awk -F, '{print $1, $2}'");
println('sorted by age:');
println(sorted);

const json = '{"users": [{"name": "alice"}, {"name": "bob"}]}';
const first_user = pipe(json, "jq -r '.users[0].name'");
println(`first user: ${first_user}`);
