n = 27;
steps = 0;

println('start:', n);

while (n != 1) {
  if (n % 2 == 0) n = n / 2;
  else n = n * 3 + 1;
  steps = steps + 1;
}

println('steps to reach 1:', steps);

n = 35;
a = 0;
b = 1;
i = 0;

while (i < n) {
  t = a + b;
  a = b;
  b = t;
  i = i + 1;
}

println('fib 35:', a);

i = 1;

while (i <= 30) {
  if (i % 15 == 0) println('FizzBuzz');
  else if (i % 3 == 0) println('Fizz');
  else if (i % 5 == 0) println('Buzz');
  else println(i);

  i = i + 1;
}

// builtins

println('hello', 'world', 42, true, nil);
println(type(3.14), type('hi'), type(true), type(nil));
println(len('flint'));
println(str(123) + ' is a string now');
println(num('99') + 1);
println('length of hello world:', len('hello world'));

n = 2;

while (n <= 30) {
  is_prime = 1;
  d = 2;

  while (d * d <= n) {
    if (n % d == 0) is_prime = 0;
    d = d + 1;
  }

  if (is_prime) println(n);
  n = n + 1;
}
